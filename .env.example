# ============================================================
# HR RAG Assistant — 环境变量
# 复制此文件为 .env 并根据需要修改
# ============================================================

# 服务端口（默认 3000）
PORT=3000

# JWT 签名密钥（生产环境请修改为随机字符串）
JWT_SECRET=hr-rag-assistant-secret

# Ollama 服务地址（本地默认 http://127.0.0.1:11434）
OLLAMA_BASE_URL=http://127.0.0.1:11434

# LLM 模型（需要先在 Ollama 中下载：ollama pull qwen2.5:7b-instruct）
LLM_MODEL=qwen2.5:7b-instruct
LLM_TIMEOUT=60000
LLM_MAX_RETRIES=2

# Embedding 模型（需要先在 Ollama 中下载：ollama pull nomic-embed-text）
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_TIMEOUT=30000
EMBEDDING_MAX_RETRIES=3
EMBEDDING_BATCH_SIZE=10
