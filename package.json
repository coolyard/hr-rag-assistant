{
  "name": "hr-rag-assistant",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter api start:dev",
    "dev:web": "pnpm --filter web dev",
    "dev": "concurrently -n api,web -c blue,green \"pnpm run dev:api\" \"pnpm run dev:web\"",
    "build": "pnpm --filter web build && pnpm --filter api build",
    "start": "pnpm --filter api start:prod",
    "preview": "pnpm build && pnpm start",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,css,html,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,css,html,md}\"",
    "test": "pnpm --recursive test",
    "test:coverage": "pnpm --recursive test:coverage",
    "test:e2e": "pnpm --filter web test:e2e",
    "eval": "pnpm --filter api eval"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-plugin-import-x": "^4.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  },
  "version": "1.3.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  }
}
